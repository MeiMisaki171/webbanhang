# PostgreSQL (self-hosted)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dien_gia_dung_pro?schema=public

# NestJS API
API_PORT=3001
API_PUBLIC_URL=http://localhost:3001
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
CORS_ORIGINS=http://localhost:3000

# Next.js web
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# S3-compatible object storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=dien-gia-dung-pro
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/dien-gia-dung-pro

# Bank transfer (display)
BANK_NAME=Vietcombank
BANK_ACCOUNT=0123456789
BANK_HOLDER=DIEN GIA DUNG PRO
BANK_QR_URL=https://placehold.co/240x240/png?text=QR

# Commerce defaults
SHIPPING_FLAT_FEE=30000
LOW_STOCK_THRESHOLD=5

# Seed credentials (local/staging only)
SEED_ADMIN_EMAIL=admin@diengiadungpro.local
SEED_ADMIN_PASSWORD=Admin@12345
SEED_CUSTOMER_EMAIL=customer@diengiadungpro.local
SEED_CUSTOMER_PASSWORD=Customer@12345
